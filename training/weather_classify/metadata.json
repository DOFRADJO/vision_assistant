{
  "model": "weather_detector",
  "version": "1.0.0",
  "author": "DOFRADJO",
  "student_id": "TON_MATRICULE",
  "school": "ENSPY — Université de Yaoundé I",
  "program": "AIA-4",
  "project": "Agent Intelligent de Vision Assistée pour Personnes Malvoyantes",
  "description": "Modèle de classification météorologique basé sur MobileNetV2 (Transfer Learning), entraîné sur le Multi-class Weather Dataset (MWD).",
  "architecture": "MobileNetV2",
  "framework": "PyTorch + TorchVision",
  "input": {
    "format": "image",
    "size": [
      224,
      224
    ],
    "channels": 3,
    "normalization": "ImageNet (mean=[0.485,0.456,0.406], std=[0.229,0.224,0.225])"
  },
  "output": {
    "format": "json",
    "structure": {
      "model": "string",
      "detections": [
        {
          "label": "string (cloudy | rain | shine | sunrise)",
          "confidence": "float (0-1)",
          "bbox": "[] (classification — pas de bounding box)"
        }
      ]
    },
    "example": {
      "model": "weather_detector",
      "detections": [
        {
          "label": "rain",
          "confidence": 0.94,
          "bbox": []
        }
      ]
    }
  },
  "classes": {
    "0": "cloudy",
    "1": "rain",
    "2": "shine",
    "3": "sunrise"
  },
  "num_classes": 4,
  "files": {
    "pytorch": "best.pt",
    "onnx": "best.onnx",
    "labels": "labels.txt",
    "metadata": "metadata.json"
  },
  "training": {
    "dataset": "Multi-class Weather Dataset (MWD) — Mendeley Data",
    "dataset_url": "https://data.mendeley.com/datasets/4drtyfjtfy/1",
    "epochs": 30,
    "image_size": 224,
    "batch_size": 32,
    "optimizer": "Adam",
    "learning_rate": 0.001,
    "best_val_accuracy": 0.9333,
    "date": "2026-06-29"
  },
  "onnx": {
    "opset": 12,
    "input_name": "input",
    "output_name": "output",
    "compatible_with": [
      "ONNX Runtime",
      "ONNX Runtime Mobile",
      "React Native"
    ]
  }
}