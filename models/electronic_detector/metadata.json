{
  "model": "electronic_detector",
  "version": "2.0.0",
  "author": "BILOA ABADJECK PAOLO",
  "student_id": "22P009",
  "school": "ENSPY - Universite de Yaounde I",
  "program": "AIA-4",
  "project": "Agent Intelligent de Vision Assistee pour Personnes Malvoyantes",
  "description": "Modele de detection d'appareils electroniques - 11 classes - YOLOv8n",
  "architecture": "YOLOv8n",
  "framework": "Ultralytics YOLOv8",
  "input": {
    "format": "image",
    "size": [
      640,
      640
    ],
    "channels": 3,
    "normalization": "0-1"
  },
  "output": {
    "format": "json",
    "structure": {
      "model": "string",
      "detections": [
        {
          "label": "string",
          "confidence": "float (0-1)",
          "bbox": "[x1, y1, x2, y2] en pixels"
        }
      ]
    },
    "example": {
      "model": "electronic_detector",
      "detections": [
        {
          "label": "laptop",
          "confidence": 0.93,
          "bbox": [
            120,
            85,
            400,
            300
          ]
        },
        {
          "label": "phone",
          "confidence": 0.88,
          "bbox": [
            450,
            200,
            520,
            380
          ]
        },
        {
          "label": "headphones",
          "confidence": 0.81,
          "bbox": [
            200,
            100,
            350,
            250
          ]
        }
      ]
    }
  },
  "classes": {
    "0": "phone",
    "1": "laptop",
    "2": "monitor",
    "3": "tv",
    "4": "tablet",
    "5": "keyboard",
    "6": "mouse",
    "7": "printer",
    "8": "microphone",
    "9": "headphones",
    "10": "camera"
  },
  "num_classes": 11,
  "files": {
    "pytorch": "best.pt",
    "onnx": "best.onnx",
    "labels": "labels.txt",
    "metadata": "metadata.json"
  },
  "training": {
    "dataset": "Open Images V6 - 11 classes electroniques",
    "epochs": 120,
    "image_size": 640,
    "batch_size": 16,
    "optimizer": "auto",
    "date": "2026-06-30"
  },
  "onnx": {
    "opset": 12,
    "simplified": true,
    "compatible_with": [
      "ONNX Runtime",
      "ONNX Runtime Mobile",
      "React Native"
    ]
  }
}